<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Теплота | Инженерные системы под ключ</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com" rel="preconnect"/>
  <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet"/>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Montserrat', 'sans-serif'],
            serif: ['Playfair Display', 'serif'],
          },
          colors: {
            brand: {
              DEFAULT: '#E65100', // Orange primary
              dark: '#BF360C',
              light: '#FFCC80',
              bg: '#F5F5F5',
              text: '#333333',
              gray: '#757575',
              border: '#E0E0E0'
            }
          }
        }
      }
    }
  </script>
  <style>
    .glass-effect {
      background: rgba(255, 255, 255, 0.75);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.3);
    }
    .glass-effect-orange {
       background: rgba(230, 81, 0, 0.85);
       backdrop-filter: blur(8px);
       color: white;
    }
    /* Custom spacing for fixed header */
    main { padding-top: 80px; }
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    
    /* Reveal animation */
    .reveal-item { opacity: 0; transform: translateY(30px); transition: all 0.8s ease-out; }
    .reveal-item.active { opacity: 1; transform: translateY(0); }
  </style>
  <link rel="stylesheet" href="admin.css"> <!-- Fallback for editor styles -->
</head>
<body class="font-sans text-brand-text bg-brand-bg antialiased selection:bg-brand selection:text-white">

  <!-- CMS EDITOR UI - TOPBAR (stays legacy style for functionality) -->
  <div id="cms-topbar" class="fixed top-0 left-0 w-full z-[100] bg-gray-900 text-white flex items-center justify-between px-6 py-2 text-xs font-semibold" style="display:none;">
    <div><span>✏️</span> Режим редактора</div>
    <div class="flex gap-2">
      <button class="bg-gray-700 px-3 py-1 rounded" id="cms-preview-btn">Предпросмотр</button>
      <button class="bg-orange-600 px-3 py-1 rounded" onclick="TepCMS.save()">Сохранить</button>
    </div>
  </div>

  <header class="fixed top-0 left-0 w-full z-50 bg-white/80 backdrop-blur-md shadow-sm">
    <div class="container mx-auto px-4 md:px-8 py-4 flex items-center justify-between">
      <a class="flex items-center gap-2" href="#">
        <img src="assets/logo.svg" alt="Teplota" class="h-8 w-auto">
        <span class="font-bold text-xl tracking-wider text-gray-800">TEPLOTA</span>
      </a>
      <nav class="hidden md:flex items-center gap-8 font-medium text-sm text-gray-700">
        <a class="hover:text-brand transition-colors" href="#about">О нас</a>
        <a class="hover:text-brand transition-colors" href="#advantages">Преимущества</a>
        <a class="hover:text-brand transition-colors" href="#services">Услуги</a>
        <a class="hover:text-brand transition-colors" href="#products">Продукция</a>
        <a class="hover:text-brand transition-colors" href="#portfolio">Портфолио</a>
      </nav>
      <div class="flex items-center gap-6">
        <div class="hidden lg:block font-semibold text-gray-800 hover:text-brand transition-colors" id="header-phone-val">+7 (800) 000-00-00</div>
        <button class="bg-brand hover:bg-brand-dark text-white px-6 py-2.5 rounded-full font-medium text-sm transition-colors shadow-md">
          Заказать звонок
        </button>
      </div>
    </div>
  </header>

  <main>
    <section class="relative h-[85vh] min-h-[600px] flex items-center overflow-hidden" id="home">
      <!-- Background Image from CMS/Local -->
      <div class="absolute inset-0 bg-cover bg-center transition-transform duration-1000 scale-105" style="background-image: url('assets/hero_bg_1775505447491.png');"></div>
      <div class="container mx-auto px-4 md:px-8 relative z-10">
        <div class="glass-effect rounded-3xl p-8 md:p-12 max-w-2xl shadow-2xl reveal-item">
          <p class="text-xs font-bold tracking-widest text-brand uppercase mb-4" id="hero-label">Инженерные системы под ключ</p>
          <h1 class="font-serif text-5xl md:text-7xl font-bold text-gray-900 leading-tight mb-6" id="hero-title">
            КОМПЛЕКСНЫЙ<br/><span class="text-brand">МОНТАЖ</span>
          </h1>
          <p class="text-gray-700 mb-8 leading-relaxed max-w-lg" id="hero-subtitle">
            Профессиональное проектирование и установка систем отопления, водоснабжения и канализации для частных домов и коммерческих объектов.
          </p>
          <div class="flex flex-wrap gap-4">
            <button class="bg-brand hover:bg-brand-dark text-white px-8 py-3.5 rounded-full font-semibold transition-colors shadow-lg shadow-brand/20">
              Рассчитать стоимость
            </button>
            <button class="bg-white hover:bg-gray-50 text-gray-800 px-8 py-3.5 rounded-full font-semibold transition-colors shadow-md border border-gray-100">
              Наши работы
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         ABOUT & PARTNERS
    ═══════════════════════════════════════════════════════ -->
    <section id="about" class="about" style="position:relative;">
      <div class="container">
        <div class="about-grid">
          <div class="about-text reveal-item">
            <span class="label" id="about-label">О компании</span>
            <h2 id="about-title">Более 10 лет <span>заботимся</span><br>о вашем комфорте</h2>
            <div class="stats-grid" id="stats-grid">
              <!-- Rendered by CMS -->
            </div>
          </div>
          <div class="about-info reveal-item">
            <div class="large-p" id="about-text1">Мы специализируемся на проектировании и монтаже инженерных систем любой сложности.</div>
            <div class="rich-text" id="about-text2">Наши специалисты проходят регулярную сертификацию у ведущих мировых производителей оборудования.</div>
          </div>
        </div>
        <div class="partners-section reveal-item">
          <div class="partners-grid" id="partners-grid">
            <!-- Rendered by CMS -->
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         ADVANTAGES
    ═══════════════════════════════════════════════════════ -->
    <section id="advantages" class="advantages">
      <div class="container">
        <div class="section-head reveal-item">
          <h2 id="advantages-title">Наши <span>преимущества</span></h2>
        </div>
        <div class="advantage-grid" id="advantage-grid">
          <!-- Rendered by CMS -->
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         SERVICES
    ═══════════════════════════════════════════════════════ -->
    <section id="services" class="services">
      <div class="container">
        <div class="section-head reveal-item">
          <h2 id="services-title">Наши <span>услуги</span></h2>
          <p>Комплексный подход к инженерным сетям</p>
        </div>
        <div class="service-grid" id="service-grid">
          <!-- Rendered by CMS -->
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         PRODUCTS
    ═══════════════════════════════════════════════════════ -->
    <section id="products" class="products">
      <div class="container">
        <div class="section-head reveal-item">
          <h2 id="products-title">Наши <span>товары</span></h2>
          <a href="#contacts" class="btn-link">Заказать оборудование →</a>
        </div>
        <div class="product-grid" id="product-grid">
          <!-- Rendered by CMS -->
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         GALLERY
    ═══════════════════════════════════════════════════════ -->
    <section id="gallery" class="gallery">
      <div class="container">
        <div class="section-head reveal-item">
          <h2>Наши <span>работы</span></h2>
          <p>Наведите на проект, чтобы узнать подробнее</p>
        </div>
        <div class="gallery-grid" id="gallery-grid">
          <!-- Rendered by CMS -->
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         CONTACT
    ═══════════════════════════════════════════════════════ -->
    <section id="contacts" class="contact">
      <div class="map-container reveal-item">
        <div id="leaflet-map"></div>
      </div>
      <div class="container">
        <div class="contact-grid">
          <div class="contact-info reveal-item">
            <span class="label">Связаться с нами</span>
            <h2>Готовы начать <br><span>свой проект?</span></h2>
            <div id="contact-phones-list" class="contact-phones-list">
              <!-- Rendered by CMS -->
            </div>
            <p id="contact-email" class="email">info@teplota-kazan.ru</p>
            <p id="contact-address" class="address">г. Казань, ул. Техническая, д. 23</p>
            <div class="contact-form">
              <div class="form-group"><input type="text" placeholder="Ваше имя"></div>
              <div class="form-group"><input type="tel" placeholder="Номер телефона"></div>
              <button class="btn">Заказать звонок</button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- ═══════════════════════════════════════════════════════════
       FOOTER
  ═══════════════════════════════════════════════════════════ -->
  <footer style="position:relative;">
    <div class="container">
      <div class="footer-top">
        <div class="footer-logo">
          <img src="assets/logo.svg" alt="Теплота" style="height:24px;opacity:0.6;">
        </div>
        <div class="social-icons" id="footer-socials">
          <!-- Rendered by CMS -->
        </div>
      </div>
      <div class="footer-bottom">
        <p id="footer-copy">© 2026 Теплота. Все права защищены.</p>
        <div class="footer-links" id="footer-links">
          <!-- Rendered by CMS -->
        </div>
      </div>
    </div>
  </footer>

  <!-- Scripts -->
  <!-- Modals and Scripts -->
  
  <!-- ═══════════════════════════════════════════════════════════
       CMS MODAL (Editor panels)
  ═══════════════════════════════════════════════════════════ -->
  <div id="cms-modal-overlay" onclick="if(event.target===this)this.classList.remove('open')">
    <div id="cms-modal">
      <div id="cms-modal-header">
        <h3 id="cms-modal-title">Редактировать</h3>
        <button id="cms-modal-close" onclick="document.getElementById('cms-modal-overlay').classList.remove('open')">×</button>
      </div>
      <div id="cms-modal-body"></div>
      <div id="cms-modal-footer">
        <button class="cms-btn secondary" onclick="document.getElementById('cms-modal-overlay').classList.remove('open')">Отмена</button>
        <button class="cms-btn primary" id="cms-modal-save">Сохранить</button>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       SERVICE DETAIL MODAL (Visitor view)
  ═══════════════════════════════════════════════════════════ -->
  <div id="service-modal-overlay" onclick="if(event.target===this)this.classList.remove('open')">
    <div id="service-modal">
      <button id="service-modal-close" onclick="document.getElementById('service-modal-overlay').classList.remove('open')">×</button>
      <img id="service-modal-cover" src="" alt="">
      <div id="service-modal-body">
        <div id="service-modal-title"></div>
        <p id="service-modal-desc"></p>
        <div id="service-modal-photos"></div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       GALLERY PROJECT MODAL (Slider)
  ═══════════════════════════════════════════════════════════ -->
  <div id="gallery-modal-overlay" onclick="if(event.target===this)this.classList.remove('open')">
    <div id="gallery-modal-container">
      <button id="gallery-modal-close" onclick="document.getElementById('gallery-modal-overlay').classList.remove('open')">×</button>
      
      <div id="gallery-modal-slider">
        <button class="slider-arrow prev" onclick="TepCMS.galleryPrev()">‹</button>
        <div id="gallery-modal-main-img-wrap">
          <img id="gallery-modal-main-img" src="" alt="">
          <div id="gallery-image-caption"></div>
        </div>
        <button class="slider-arrow next" onclick="TepCMS.galleryNext()">›</button>
        
        <div id="gallery-modal-counter">1 / 1</div>
      </div>

      <div id="gallery-modal-info">
        <h3 id="gallery-modal-title"></h3>
        <p id="gallery-modal-desc"></p>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       PRODUCT DETAIL MODAL (Visitor view)
  ═══════════════════════════════════════════════════════════ -->
  <div id="product-modal-overlay" onclick="if(event.target===this)this.classList.remove('open')">
    <div id="product-modal">
      <button id="product-modal-close" onclick="document.getElementById('product-modal-overlay').classList.remove('open')">×</button>
      <div id="product-modal-image-wrap">
        <img id="product-modal-cover" src="" alt="">
      </div>
      <div id="product-modal-body">
        <div id="product-modal-title"></div>
        <div id="product-modal-desc"></div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       FULLSCREEN IMAGE VIEWER
  ═══════════════════════════════════════════════════════════ -->
  <div id="img-viewer-overlay" onclick="if(event.target===this)this.classList.remove('open')">
    <button id="img-viewer-close" onclick="document.getElementById('img-viewer-overlay').classList.remove('open')">×</button>
    <img src="" alt="Просмотр">
  </div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script type="module" src="cms.js"></script>
<script type="module" src="main.js"></script>
</body>
</html>
